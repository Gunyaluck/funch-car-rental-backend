# Supabase pooled connection for Prisma Client at runtime.
# For serverless/short-lived connections use port 6543 with pgbouncer=true.
DATABASE_URL="postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase direct or session connection for Prisma CLI and Migrate.
# Prefer the direct db host if your environment supports IPv6.
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
JWT_SECRET="your_jwt_secret"
JWT_EXPIRES_IN="7d"
PORT=4000
FRONTEND_URL="http://localhost:5173"
# Comma-separated allowed frontend origins for CORS.
FRONTEND_URLS="http://localhost:5173,https://your-frontend.vercel.app"
